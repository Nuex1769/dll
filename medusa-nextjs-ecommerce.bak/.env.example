# ============================================
# Medusa Backend Environment Variables
# ============================================

# Database Configuration
DATABASE_URL=postgresql://medusa:password@localhost:5432/medusa_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT & Security
JWT_SECRET=your_jwt_secret_key_here
COOKIE_SECRET=your_cookie_secret_key_here

# Medusa Server Configuration
MEDUSA_ADMIN_ONBOARDING_TYPE=quickstart
NODE_ENV=development
DISABLE_MEDUSA_ADMIN=false

# CORS Configuration
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=*

# ============================================
# Payment Providers
# ============================================

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox # sandbox or live
PAYPAL_WEBHOOK_ID=your_webhook_id

# ============================================
# Next.js Frontend Environment Variables
# ============================================

# Medusa API
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe Public Key
NEXT_PUBLIC_STRIPE_KEY=pk_test_your_stripe_public_key

# PayPal Public Client ID
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# Supported Locales
NEXT_PUBLIC_SUPPORTED_LOCALES=en,zh,ja,de

# ============================================
# Optional Services
# ============================================

# Sentry Error Tracking
SENTRY_DSN=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=

# Cloudinary CDN
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ============================================
# Email Configuration (Optional)
# ============================================

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@yourstore.com

# ============================================
# Deployment
# ============================================

# Vercel
VERCEL_ENV=
VERCEL_URL=

# Docker
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
